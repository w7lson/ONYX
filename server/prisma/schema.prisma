generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model UserProfile {
  id               String            @id @default(uuid())
  clerkId          String            @unique
  email            String            @unique
  quizResults      Json?
  learningStyle    String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  plans            LearningPlan[]
  decks            Deck[]
  pomodoroSessions PomodoroSession[]
  tests            Test[]
  goals            Goal[]
}

model LearningPlan {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    UserProfile @relation(fields: [userId], references: [clerkId])
  modules Module[]
}

model Module {
  id               String @id @default(uuid())
  planId           String
  title            String
  estimatedMinutes Int
  order            Int

  plan  LearningPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  tasks Task[]
}

model Task {
  id          String  @id @default(uuid())
  moduleId    String
  content     String
  isCompleted Boolean @default(false)

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

// ===== FLASHCARDS / SPACED REPETITION =====

model Deck {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  UserProfile @relation(fields: [userId], references: [clerkId])
  cards Flashcard[]
}

model Flashcard {
  id             String    @id @default(uuid())
  deckId         String
  front          String
  back           String
  easeFactor     Float     @default(2.5)
  interval       Int       @default(0)
  repetitions    Int       @default(0)
  nextReviewAt   DateTime  @default(now())
  lastReviewedAt DateTime?
  createdAt      DateTime  @default(now())

  deck    Deck              @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviews FlashcardReview[]
}

model FlashcardReview {
  id         String   @id @default(uuid())
  cardId     String
  quality    Int
  reviewedAt DateTime @default(now())

  card Flashcard @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

// ===== POMODORO =====

model PomodoroSession {
  id           String   @id @default(uuid())
  userId       String
  durationMin  Int
  completedAt  DateTime @default(now())
  wasCompleted Boolean  @default(true)
  label        String?

  user UserProfile @relation(fields: [userId], references: [clerkId])
}

// ===== AI TESTS =====

model Test {
  id          String    @id @default(uuid())
  userId      String
  topic       String
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  score       Float?

  user      UserProfile    @relation(fields: [userId], references: [clerkId])
  questions TestQuestion[]
}

model TestQuestion {
  id            String   @id @default(uuid())
  testId        String
  type          String
  questionText  String
  options       Json?
  correctAnswer String
  userAnswer    String?
  isCorrect     Boolean?
  aiFeedback    String?

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)
}

// ===== GOALS =====

model Goal {
  id          String      @id @default(uuid())
  userId      String
  title       String
  description String?
  focus       String      @default("Uncategorized")
  duration    String
  reward      String?
  targetDate  DateTime?
  status      String      @default("draft")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user       UserProfile  @relation(fields: [userId], references: [clerkId])
  milestones Milestone[]
}

model Milestone {
  id          String    @id @default(uuid())
  goalId      String
  title       String
  description String?
  reward      String?
  targetDate  DateTime?
  order       Int
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
}
