{
  "version": 2,
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "server/src/**",
          "server/prisma/**",
          "server/node_modules/.prisma/client/**",
          "server/node_modules/@prisma/client/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "src/index.js" }
  ]
}
